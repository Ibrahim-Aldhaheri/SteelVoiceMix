# SteelSeries Arctis Nova Pro Wireless — allow non-root access to base station
KERNEL=="hidraw*", ATTRS{idVendor}=="1038", ATTRS{idProduct}=="12e0", MODE="0666"

# Auto-start nova-mixer when base station is plugged in (optional — requires systemd service)
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="1038", ATTR{idProduct}=="12e0", TAG+="systemd", ENV{SYSTEMD_USER_WANTS}="nova-mixer.service"
